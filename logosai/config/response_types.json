    "ANALYTICS": "ANALYSIS",
    "DATA": "ANALYSIS",
    "FAIL": "ERROR",
    "EXCEPTION": "ERROR",
    "OK": "SUCCESS",
    "DONE": "SUCCESS",
    "INCOMPLETE": "PARTIAL",
