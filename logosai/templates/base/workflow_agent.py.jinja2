    async def setup(self) -> None:
        """Set up workflow resources"""
        await super().setup()
        
        # Validate workflow configuration
        self._validate_workflow()
        
        self.logger.info(f"{self.name} workflow initialized with {len(self.workflow_steps)} steps")
        
    def _validate_workflow(self):
        """Validate workflow configuration"""
        for step in self.workflow_steps:
            # Check if handler method exists
            if not hasattr(self, step.handler):
                raise ValueError(f"Handler method '{step.handler}' not found for step '{step.name}'")
                
            # Check if condition method exists
            if step.condition and not hasattr(self, step.condition):
                raise ValueError(f"Condition method '{step.condition}' not found for step '{step.name}'")
                
    async def process(self, input_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        Execute the workflow.
        
        Args:
            input_data: Input data for the workflow
            
        Returns:
            Workflow execution results
        """
        try:
            # Initialize context with input data
            self.context = self.validate_input(input_data)
            self.step_results.clear()
            
            # Group steps for execution
            step_groups = self._group_steps()
            
            # Execute step groups
            for group in step_groups:
                if len(group) == 1:
                    # Sequential execution
                    await self._execute_step(group[0])
                else:
                    # Parallel execution
                    await self._execute_parallel_steps(group)
                    
                # Check if workflow should continue
                if self._should_stop_workflow():
                    break
                    
            return self.format_output(self._prepare_final_result())
            
        except Exception as e:
            self.logger.error(f"Workflow execution failed: {str(e)}")
            raise LogosAIException(f"Workflow failed: {str(e)}")
            
    def _group_steps(self) -> List[List[WorkflowStep]]:
        """Group steps for sequential/parallel execution"""
        groups = []
        current_group = []
        
        for step in self.workflow_steps:
            if step.parallel and current_group:
                current_group.append(step)
            else:
                if current_group:
                    groups.append(current_group)
                current_group = [step]
                
        if current_group:
            groups.append(current_group)
            
        return groups
        
    async def _execute_step(self, step: WorkflowStep) -> StepResult:
        """Execute a single workflow step"""
        import time
        start_time = time.time()
        
        # Check condition
        if step.condition:
            condition_method = getattr(self, step.condition)
            if not await condition_method(self.context):
                result = StepResult(
                    step_name=step.name,
                    status=StepStatus.SKIPPED,
                    duration=time.time() - start_time
                )
                self.step_results[step.name] = result
                self.logger.info(f"Step '{step.name}' skipped due to condition")
                return result
                
        # Execute with retry
        last_error = None
        
        for attempt in range(step.retry_count):
            try:
                self.logger.info(f"Executing step '{step.name}' (attempt {attempt + 1}/{step.retry_count})")
                
                # Get handler method
                handler = getattr(self, step.handler)
                
                # Execute with timeout if specified
                if step.timeout:
                    result_data = await asyncio.wait_for(
                        handler(self.context),
                        timeout=step.timeout
                    )
                else:
                    result_data = await handler(self.context)
                    
                # Success
                result = StepResult(
                    step_name=step.name,
                    status=StepStatus.SUCCESS,
                    data=result_data,
                    duration=time.time() - start_time
                )
                self.step_results[step.name] = result
                
                # Update context if result is a dict
                if isinstance(result_data, dict):
                    self.context.update(result_data)
                    
                return result
                
            except Exception as e:
                last_error = e
                self.logger.error(f"Step '{step.name}' failed (attempt {attempt + 1}): {e}")
                
                if attempt < step.retry_count - 1:
                    await asyncio.sleep(2 ** attempt)  # Exponential backoff
                    
        # All attempts failed
        result = StepResult(
            step_name=step.name,
            status=StepStatus.FAILED,
            error=str(last_error),
            duration=time.time() - start_time
        )
        self.step_results[step.name] = result
        
        # Handle error based on configuration
        if step.on_error == "fail":
            raise last_error
        elif step.on_error == "skip":
            self.logger.warning(f"Step '{step.name}' failed but continuing workflow")
            
        return result
        
    async def _execute_parallel_steps(self, steps: List[WorkflowStep]) -> List[StepResult]:
        """Execute multiple steps in parallel"""
        tasks = [self._execute_step(step) for step in steps]
        results = await asyncio.gather(*tasks, return_exceptions=True)
        
        # Handle exceptions
        for i, result in enumerate(results):
            if isinstance(result, Exception):
                step = steps[i]
                if step.on_error == "fail":
                    raise result
                    
        return results
        
    def _should_stop_workflow(self) -> bool:
        """Check if workflow should stop based on step results"""
        for result in self.step_results.values():
            if result.status == StepStatus.FAILED:
                return True
        return False
        
    def _prepare_final_result(self) -> Dict[str, Any]:
        """Prepare final workflow result"""
        return {
            "workflow_status": self._get_workflow_status(),
            "steps_executed": len(self.step_results),
            "step_results": {
                name: {
                    "status": result.status.value,
                    "duration": result.duration,
                    "error": result.error
                }
                for name, result in self.step_results.items()
            },
            "context": self.context,
            "output": self.context.get("final_output", {})
        }
        
    def _get_workflow_status(self) -> str:
        """Determine overall workflow status"""
        statuses = [r.status for r in self.step_results.values()]
        
        if any(s == StepStatus.FAILED for s in statuses):
            return "failed"
        elif all(s in [StepStatus.SUCCESS, StepStatus.SKIPPED] for s in statuses):
            return "success"
        else:
            return "partial"
            
    def validate_input(self, input_data: Dict[str, Any]) -> Dict[str, Any]:
        """Validate workflow input"""
        if not isinstance(input_data, dict):
            raise ValueError("Workflow input must be a dictionary")
        return input_data
        
