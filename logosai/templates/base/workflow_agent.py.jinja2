import logging

logger = logging.getLogger(__name__)


class StepStatus(Enum):
    """Workflow step execution status"""
    PENDING = "pending"
    RUNNING = "running"
    SUCCESS = "success"
    FAILED = "failed"
    SKIPPED = "skipped"


@dataclass
class WorkflowStep:
    """Definition of a workflow step"""
    name: str
    handler: str  # Method name to call
    description: str = ""
    condition: Optional[str] = None  # Method name for condition check
    retry_count: int = 1
    timeout: Optional[float] = None
    parallel: bool = False
    on_error: str = "fail"  # "fail", "continue", or "skip"
    

@dataclass
class StepResult:
    """Result of a workflow step execution"""
    step_name: str
    status: StepStatus
    data: Any = None
    error: Optional[str] = None
    duration: float = 0.0


