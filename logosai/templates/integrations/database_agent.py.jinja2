        {% endif %}
        
    def validate_input(self, input_data: Dict[str, Any]) -> Dict[str, Any]:
        """Validate database operation input"""
        if 'operation' not in input_data:
            raise ValueError("Missing required field: operation")
            
        operation = input_data['operation']
        valid_operations = ['query', 'insert', 'update', 'delete', 'transaction']
        
        if operation not in valid_operations:
            raise ValueError(f"Invalid operation: {operation}")
            
        # Operation-specific validation
        if operation == 'query' and 'query' not in input_data:
            raise ValueError("Query operation requires 'query' field")
        elif operation in ['insert', 'update'] and 'data' not in input_data:
            raise ValueError(f"{operation} operation requires 'data' field")
        elif operation == 'delete' and 'where' not in input_data:
            raise ValueError("Delete operation requires 'where' field")
            
        return input_data
        
    def format_output(self, result: Any) -> Dict[str, Any]:
        """Format database operation output"""
        return {
            "status": "success",
            "data": result,
            "metadata": {
                "agent": self.name,
                "version": self.version,
                "timestamp": self.get_timestamp(),
                "processing_time": self.get_processing_time(),
                "database": self.db_config.get('database'),
                "cache_size": len(self._query_cache)
            }
        }
        
    async def cleanup(self) -> None:
        """Clean up database resources"""
        # Clear caches
        self._query_cache.clear()
        self._prepared_statements.clear()
        
        # Close connection pool
        if self.pool:
            {% if db_config.type == "postgresql" %}
            await self.pool.close()
            {% elif db_config.type == "mysql" %}
            self.pool.close()
            await self.pool.wait_closed()
            {% endif %}
            
        await super().cleanup()
        self.logger.info(f"{self.name} database cleanup completed")