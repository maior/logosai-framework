                pass
            else:
                # Use multi-value INSERT
                query = f"INSERT INTO {table} ({', '.join(columns)}) VALUES " + \
                       ", ".join([f"({', '.join([f'${i*len(columns)+j+1}' for j in range(len(columns))])})" 
                                 for i in range(len(data))])
                                 
                flat_values = [val for values in values_list for val in values]
                await conn.execute(query, *flat_values)
                
        return {"inserted": len(data)}
        {% else %}
