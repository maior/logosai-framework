    async def _handle_transaction(self, params: Dict[str, Any]) -> Any:
        """Handle multiple operations in a transaction"""
        operations = params['operations']
        results = []
        
        async with self.transaction() as conn:
            for op in operations:
                # Execute each operation within the transaction
                if op['type'] == 'query':
                    result = await self._execute_in_transaction(conn, op)
                    results.append(result)
                # Add other operation types as needed
                
        return {"transaction": "completed", "results": results}
        
    def _build_where_clause(self, conditions: Union[Dict, str], 
                           param_offset: int) -> tuple:
        """Build WHERE clause from conditions"""
        if isinstance(conditions, str):
            return conditions, []
            
        clauses = []
        values = []
        
        for i, (key, value) in enumerate(conditions.items()):
            if isinstance(value, (list, tuple)):
                # IN clause
                placeholders = [f"${param_offset + i + j + 1}" for j in range(len(value))]
                clauses.append(f"{key} IN ({', '.join(placeholders)})")
                values.extend(value)
            else:
                clauses.append(f"{key} = ${param_offset + i + 1}")
                values.append(value)
                
        return " AND ".join(clauses), values
        
    async def _bulk_insert(self, table: str, data: List[Dict], 
                          returning: Optional[str] = None) -> Any:
        """Perform bulk insert operation"""
        if not data:
            return {"inserted": 0}
            
        # Ensure all records have the same columns
        columns = list(data[0].keys())
        values_list = []
        
        for record in data:
            values = [record.get(col) for col in columns]
            values_list.append(values)
            
        {% if db_config.type == "postgresql" %}
