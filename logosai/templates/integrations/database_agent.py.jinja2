    def __init__(self):
        """Initialize the database agent"""
        super().__init__(
            name="{{ agent_name }}",
            description="{{ description }}",
            version="1.0.0"
        )
        
        # Database configuration
        self.db_config = {{ db_config | tojson }}
        self.pool_size = {{ pool_size | default(10) }}
        self.max_overflow = {{ max_overflow | default(20) }}
        self.pool_timeout = {{ pool_timeout | default(30) }}
        
        self.pool: Optional[Any] = None
        self._query_cache: Dict[str, Any] = {}
        self._prepared_statements: Dict[str, Any] = {}
        
    async def setup(self) -> None:
        """Set up database connection pool"""
        await super().setup()
        
        try:
            await self._create_connection_pool()
            await self._initialize_database()
            self.logger.info(f"{self.name} database setup completed")
        except Exception as e:
            self.logger.error(f"Database setup failed: {e}")
            raise LogosAIException(f"Failed to setup database: {e}")
            
    async def _create_connection_pool(self) -> None:
        """Create database connection pool"""
        {% if db_config.type == "postgresql" %}
        # PostgreSQL connection pool
        self.pool = await asyncpg.create_pool(
            host=self.db_config.get('host', 'localhost'),
            port=self.db_config.get('port', 5432),
            user=self.db_config.get('user'),
            password=self.db_config.get('password'),
            database=self.db_config.get('database'),
            min_size=self.pool_size,
            max_size=self.pool_size + self.max_overflow,
            command_timeout=self.pool_timeout
        )
        {% elif db_config.type == "mysql" %}
        # MySQL connection pool
        self.pool = await aiomysql.create_pool(
            host=self.db_config.get('host', 'localhost'),
            port=self.db_config.get('port', 3306),
            user=self.db_config.get('user'),
            password=self.db_config.get('password'),
            db=self.db_config.get('database'),
            minsize=self.pool_size,
            maxsize=self.pool_size + self.max_overflow
        )
        {% else %}
        # TODO: Implement connection pool for {{ db_config.type }}
        raise NotImplementedError(f"Database type {self.db_config['type']} not implemented")
        {% endif %}
        
    async def _initialize_database(self) -> None:
        """Initialize database schema and prepared statements"""
        {% if init_queries %}
        # Run initialization queries
        async with self.get_connection() as conn:
            {% for query in init_queries %}
            await conn.execute("""{{ query }}""")
            {% endfor %}
        {% endif %}
        
        {% if prepared_statements %}
        # Prepare statements
        async with self.get_connection() as conn:
            {% for name, query in prepared_statements.items() %}
            self._prepared_statements['{{ name }}'] = await conn.prepare("""{{ query }}""")
            {% endfor %}
        {% endif %}
        
    async def process(self, input_data: Dict[str, Any]) -> Dict[str, Any]:
        """
        Process database operations.
        
        Args:
            input_data: Dictionary with 'operation' and operation-specific parameters
            
        Returns:
            Operation results
        """
        try:
            validated_input = self.validate_input(input_data)
            operation = validated_input['operation']
            
            # Route to appropriate handler
            if operation == 'query':
                result = await self._handle_query(validated_input)
            elif operation == 'insert':
                result = await self._handle_insert(validated_input)
            elif operation == 'update':
                result = await self._handle_update(validated_input)
            elif operation == 'delete':
                result = await self._handle_delete(validated_input)
            elif operation == 'transaction':
                result = await self._handle_transaction(validated_input)
            else:
                raise ValueError(f"Unknown operation: {operation}")
                
            return self.format_output(result)
            
        except Exception as e:
            self.logger.error(f"Database operation failed: {e}")
            raise LogosAIException(f"Database operation failed: {e}")
            
    @asynccontextmanager
    async def get_connection(self):
        """Get a database connection from the pool"""
        {% if db_config.type == "postgresql" %}
        async with self.pool.acquire() as connection:
            yield connection
        {% elif db_config.type == "mysql" %}
        async with self.pool.acquire() as connection:
            async with connection.cursor() as cursor:
                yield cursor
        {% else %}
        # TODO: Implement connection context for {{ db_config.type }}
        yield None
        {% endif %}
        
    @asynccontextmanager
    async def transaction(self):
        """Execute operations within a transaction"""
        async with self.get_connection() as conn:
            {% if db_config.type == "postgresql" %}
            async with conn.transaction():
                yield conn
            {% elif db_config.type == "mysql" %}
            await conn.begin()
            try:
                yield conn
                await conn.commit()
            except Exception:
                await conn.rollback()
                raise
            {% else %}
            # TODO: Implement transaction for {{ db_config.type }}
            yield conn
            {% endif %}
            
    async def _handle_query(self, params: Dict[str, Any]) -> Any:
        """Handle SELECT queries"""
        query = params['query']
        values = params.get('values', [])
        cache_key = f"{query}:{str(values)}"
        
        # Check cache
        if params.get('use_cache', True) and cache_key in self._query_cache:
            self.logger.debug(f"Returning cached result for: {query}")
            return self._query_cache[cache_key]
            
        async with self.get_connection() as conn:
            {% if db_config.type == "postgresql" %}
            if params.get('single_row', False):
                result = await conn.fetchrow(query, *values)
                result = dict(result) if result else None
            else:
                result = await conn.fetch(query, *values)
                result = [dict(row) for row in result]
            {% elif db_config.type == "mysql" %}
            await conn.execute(query, values)
            if params.get('single_row', False):
                result = await conn.fetchone()
            else:
                result = await conn.fetchall()
            {% else %}
            # TODO: Implement query for {{ db_config.type }}
            result = None
            {% endif %}
            
        # Cache result if enabled
        if params.get('use_cache', True):
            self._query_cache[cache_key] = result
            
        return result
        
    async def _handle_insert(self, params: Dict[str, Any]) -> Any:
        """Handle INSERT operations"""
        table = params['table']
        data = params['data']
        returning = params.get('returning', None)
        
        # Build INSERT query
        if isinstance(data, list):
            # Bulk insert
            return await self._bulk_insert(table, data, returning)
        else:
            # Single insert
            columns = list(data.keys())
            values = list(data.values())
            placeholders = [f"${i+1}" for i in range(len(values))]
            
            query = f"INSERT INTO {table} ({', '.join(columns)}) VALUES ({', '.join(placeholders)})"
            if returning:
                query += f" RETURNING {returning}"
                
            async with self.get_connection() as conn:
                {% if db_config.type == "postgresql" %}
                if returning:
                    result = await conn.fetchrow(query, *values)
                    return dict(result) if result else None
                else:
                    await conn.execute(query, *values)
                    return {"inserted": 1}
                {% else %}
                # TODO: Implement insert for {{ db_config.type }}
                return {"inserted": 0}
                {% endif %}
                
    async def _handle_update(self, params: Dict[str, Any]) -> Any:
        """Handle UPDATE operations"""
        table = params['table']
        data = params['data']
        where = params['where']
        
        # Build UPDATE query
        set_clause = [f"{col} = ${i+1}" for i, col in enumerate(data.keys())]
        values = list(data.values())
        
        # Add WHERE clause
        where_clause, where_values = self._build_where_clause(where, len(values))
        values.extend(where_values)
        
        query = f"UPDATE {table} SET {', '.join(set_clause)} WHERE {where_clause}"
        
        async with self.get_connection() as conn:
            {% if db_config.type == "postgresql" %}
            result = await conn.execute(query, *values)
            # Extract number of affected rows
            affected = int(result.split()[-1]) if result else 0
            return {"updated": affected}
            {% else %}
            # TODO: Implement update for {{ db_config.type }}
            return {"updated": 0}
            {% endif %}
            
    async def _handle_delete(self, params: Dict[str, Any]) -> Any:
        """Handle DELETE operations"""
        table = params['table']
        where = params['where']
        
        # Build DELETE query
        where_clause, values = self._build_where_clause(where, 0)
